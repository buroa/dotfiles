{{- if or (eq .machine "truenas") (eq .machine "fedora") -}}
#!/usr/bin/env bash
set -euo pipefail
# Bootstrap mise before files are applied so the after-hook can read the config.
# macos gets mise from Homebrew; on Fedora IoT it usually comes from rpm-ostree,
# so the guard below makes this a no-op when mise is already present.
if ! command -v mise >/dev/null && [ ! -x "{{ .chezmoi.homeDir }}/.local/bin/mise" ]; then
    curl -fsSL https://mise.run | sh
fi
{{- end -}}
