export KUBE_EDITOR=nvim
export VISUAL=nvim
export EDITOR=nvim
export ANSIBLE_FORCE_COLOR=true
export ANSIBLE_HOST_KEY_CHECKING=False
export PY_COLORS=true
export LANG=en_US.utf-8
export CURL_HOME="{{ .chezmoi.homeDir }}/.config/curl"

typeset -U path
# mise shims first: mise activate only fixes up PATH at the first prompt, so
# rc-time and non-interactive lookups need the shims.
for dir in \
    "{{ .chezmoi.homeDir }}/.local/share/mise/shims" \
    "{{ .chezmoi.homeDir }}/.local/bin"
do
    [[ -d $dir ]] && path=($dir $path)
done
export PATH
